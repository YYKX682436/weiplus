<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="center_vertical" android:id="@android:id/background" android:height="@dimen/dv">
        <shape android:shape="rectangle">
            <corners android:radius="4.0dp" />
            <solid android:color="@color/BW_100_Alpha_0_1_5" />
        </shape>
    </item>
    <item android:gravity="center_vertical" android:id="@android:id/progress" android:height="@dimen/dv">
        <scale android:scaleWidth="100%">
            <shape>
                <corners android:radius="4.0dp" />
                <solid android:color="@color/BW_100_Alpha_0_8" />
            </shape>
        </scale>
    </item>
</layer-list>
