<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/y" />
            <solid android:color="@color/aaw" />
            <stroke android:width="@dimen/y" android:color="@color/g4" />
        </shape>
    </item>
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/y" />
            <solid android:color="@color/aaw" />
            <stroke android:width="@dimen/a0" android:color="@color/g4" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/y" />
            <solid android:color="@color/aaw" />
            <stroke android:width="@dimen/pc" android:color="@color/ga" />
        </shape>
    </item>
</selector>
