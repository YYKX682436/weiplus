<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/y" />
            <solid android:color="#0c000000" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/y" />
            <solid android:color="#b29234" />
            <stroke android:width="@dimen/a0" android:color="#b29234" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/y" />
            <solid android:color="#dfb741" />
            <stroke android:width="@dimen/a0" android:color="#dfb741" />
        </shape>
    </item>
</selector>
