<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="oval" android:useLevel="true" android:innerRadius="6.0dp" android:thickness="2.0dp">
            <stroke android:width="2.0dp" android:color="@color/BW_0_Alpha_0_2" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <rotate android:fromDegrees="270.0" android:toDegrees="270.0">
            <shape android:shape="ring" android:useLevel="true" android:innerRadius="6.0dp" android:thickness="2.0dp">
                <solid android:color="@color/aaw" />
            </shape>
        </rotate>
    </item>
</layer-list>
