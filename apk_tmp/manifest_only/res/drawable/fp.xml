<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="16.0dp" />
            <solid android:color="@color/f3" />
            <stroke android:width="2.0dp" android:color="@color/aaw" />
        </shape>
    </item>
    <item>
        <inset android:inset="4.0dp">
            <shape android:shape="rectangle">
                <corners android:radius="12.0dp" />
                <solid android:color="@color/f3" />
                <stroke android:width="2.0dp" android:color="@color/aaw" />
            </shape>
        </inset>
    </item>
</selector>
