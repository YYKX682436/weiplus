<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item android:drawable="@raw/copy_regular" android:alpha="0.15" />
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item android:drawable="@raw/copy_regular" android:alpha="0.3" />
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:drawable="@raw/copy_regular" android:alpha="1.0" />
        </layer-list>
    </item>
</selector>
