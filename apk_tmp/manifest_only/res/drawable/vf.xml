<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:topLeftRadius="1.5dp" android:topRightRadius="1.5dp" android:bottomLeftRadius="1.5dp" android:bottomRightRadius="1.5dp" />
            <solid android:color="#33ffffff" />
        </shape>
    </item>
    <item android:id="@android:id/secondaryProgress">
        <scale android:scaleWidth="100%">
            <shape>
                <corners android:topLeftRadius="1.5dp" android:topRightRadius="1.5dp" android:bottomLeftRadius="1.5dp" android:bottomRightRadius="1.5dp" />
                <solid android:color="#11ce33" />
            </shape>
        </scale>
    </item>
    <item android:id="@android:id/progress">
        <scale android:drawable="@drawable/vh" android:scaleWidth="100%" />
    </item>
</layer-list>
