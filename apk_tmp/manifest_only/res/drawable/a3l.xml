<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="#00ff6146" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <gradient android:startColor="#7dff9a3d" android:endColor="#ff6146" android:angle="270.0" android:type="linear" />
            </shape>
        </clip>
    </item>
</layer-list>
