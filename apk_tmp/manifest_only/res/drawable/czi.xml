<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="@dimen/aih" android:topRightRadius="@dimen/aih" />
            <solid android:drawable="@drawable/rk" />
        </shape>
    </item>
    <item android:state_pressed="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:topLeftRadius="@dimen/aih" android:topRightRadius="@dimen/aih" />
                    <solid android:color="@color/aio" />
                </shape>
            </item>
            <item android:state_pressed="false">
                <shape android:shape="rectangle">
                    <corners android:topLeftRadius="@dimen/aih" android:topRightRadius="@dimen/aih" />
                    <gradient android:startColor="@color/aip" android:endColor="@color/ain" android:angle="0.0" android:type="linear" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
