    <changeBounds android:duration="600">
        <targets>
            <target android:targetId="@id/ik7" />
        </targets>
    </changeBounds>
    <fade android:duration="600" android:fadingMode="fade_out">
        <targets>
            <target android:targetId="@id/ik4" />
            <target android:targetId="@id/ik8" />
            <target android:targetId="@id/ik6" />
